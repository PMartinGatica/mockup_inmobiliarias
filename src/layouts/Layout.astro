---
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import '@fontsource/bebas-neue'
import '@fontsource/barlow/400.css'
import '@fontsource/barlow/500.css'
import '@fontsource/barlow/600.css'
import '@fontsource/barlow/700.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = '9410 Arquitectura — Ushuaia, Tierra del Fuego',
  description = 'Estudio de arquitectura, construcción y desarrollo inmobiliario con sede en Ushuaia, Tierra del Fuego. Dirigido por el Arq. Carlos Escudero.',
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />

    <style is:global>
      :root {
        color-scheme: dark;
        --color-bg: #0D0D0D;
        --color-surface: #1C1C1C;
        --color-primary: #C8831A;
        --color-primary-light: #E8A84D;
        --entry-animation: -20px;
        --cover-animation: 20px;
      }

      @media (min-width: 1400px) {
        :root {
          --entry-animation: -80px;
          --cover-animation: 80px;
        }
      }

      html {
        font-family: 'Barlow', system-ui, sans-serif;
        background: var(--color-bg);
        scroll-behavior: smooth;
      }

      body {
        overflow-x: hidden;
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background: rgba(200, 131, 26, 0.35);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(200, 131, 26, 0.6);
      }

      p {
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.6;
        font-size: 1rem;
        letter-spacing: 0.3px;
        font-weight: 400;
      }

      p strong {
        color: white;
        font-weight: 600;
      }

      .text__glowing {
        transition: text-shadow 0.3s ease, color 0.3s ease;
      }
      .text__glowing:hover {
        color: var(--color-primary-light);
        text-shadow: 0 0 20px rgba(200, 131, 26, 0.5);
      }

      /* Header blur on scroll — CSS scroll timeline (igual que esland) */
      #header-nav {
        animation: header-blur linear both;
        animation-timeline: scroll();
        animation-range: 0 400px;
      }

      @keyframes header-blur {
        to {
          box-shadow:
            0px 4px 40px -4px rgba(0, 0, 0, 0.4),
            0px 0px 0 1px rgba(255, 255, 255, 0.04);
          background: rgba(13, 13, 13, 0.8);
          backdrop-filter: blur(12px);
        }
      }

      /* Grain/noise texture overlay for sections */
      .noise-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 0;
      }

      /* Section titles */
      .section-title {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 0.05em;
        color: white;
      }

      /* Highlight accent */
      .accent {
        color: var(--color-primary);
      }

      /* Btn glow */
      .btn-primary {
        transition: box-shadow 0.3s ease, text-shadow 0.3s ease, background-color 0.3s ease;
      }
      .btn-primary:hover {
        box-shadow: 0 0 20px rgba(200, 131, 26, 0.5), 0 0 40px rgba(200, 131, 26, 0.2);
      }
    </style>
  </body>
</html>
