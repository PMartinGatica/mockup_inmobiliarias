---
import WhatsappIcon from '@/components/icons/Whatsapp.astro'
import InstagramIcon from '@/components/icons/Instagram.astro'

const WA_LINK = 'https://api.whatsapp.com/send?phone=542901300925&text=Hola%209410%20Arq!%20Quisiera%20consultar%20por...'
const IG_LINK = 'https://www.instagram.com/9410arq'
const FB_LINK = 'https://www.facebook.com/9410Arquitectura'
---

<section
  id="contacto"
  class="relative w-full py-24 md:py-32 overflow-hidden"
>
  <!-- Background: subtle grid -->
  <div class="absolute inset-0 contacto-bg pointer-events-none"></div>

  <!-- Top border accent -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid md:grid-cols-2 gap-16 md:gap-20 items-start">

      <!-- Left: CTA copy -->
      <div class="flex flex-col gap-6">
        <span class="text-primary font-barlow font-600 tracking-[0.3em] text-xs uppercase">
          Hablemos
        </span>
        <h2 class="section-title text-4xl md:text-5xl lg:text-6xl leading-tight">
          ¿Tenés un<br />
          proyecto <span class="text-primary">en mente?</span>
        </h2>
        <p class="text-white/60 font-barlow text-base md:text-lg leading-relaxed max-w-md">
          Contanos tu idea. Desde una vivienda unifamiliar hasta un desarrollo inmobiliario completo,
          estamos para acompañarte en cada etapa.
        </p>

        <!-- Contact methods -->
        <div class="flex flex-col gap-4 mt-2">
          <a
            href={WA_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary flex items-center gap-3 bg-primary text-white font-barlow font-600 tracking-wider uppercase text-sm px-6 py-4 rounded-xl hover:bg-primary-light transition-colors duration-300 w-fit"
          >
            <WhatsappIcon />
            Escribinos por WhatsApp
          </a>
          <a
            href={IG_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-white/50 font-barlow text-sm tracking-wider hover:text-primary transition-colors duration-300 w-fit"
          >
            <InstagramIcon />
            @9410arq en Instagram
          </a>
          <a
            href={FB_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-white/50 font-barlow text-sm tracking-wider hover:text-primary transition-colors duration-300 w-fit"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            9410 Arquitectura en Facebook
          </a>
        </div>
      </div>

      <!-- Right: simple form -->
      <div class="bg-surface border border-white/[0.06] rounded-2xl p-8 flex flex-col gap-6">
        <h3 class="font-bebas text-2xl text-white tracking-wide">Contanos tu proyecto</h3>

        <form class="flex flex-col gap-4" action="#" method="POST">
          <div class="flex flex-col gap-1.5">
            <label class="text-white/50 font-barlow text-xs tracking-wider uppercase" for="nombre">
              Nombre
            </label>
            <input
              id="nombre"
              type="text"
              name="nombre"
              placeholder="Tu nombre"
              class="bg-[#0D0D0D] border border-white/10 rounded-lg px-4 py-3 text-white font-barlow text-sm
                     placeholder-white/20 focus:outline-none focus:border-primary/50 transition-colors duration-200"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-white/50 font-barlow text-xs tracking-wider uppercase" for="email">
              Email o teléfono
            </label>
            <input
              id="email"
              type="text"
              name="email"
              placeholder="Cómo podemos contactarte"
              class="bg-[#0D0D0D] border border-white/10 rounded-lg px-4 py-3 text-white font-barlow text-sm
                     placeholder-white/20 focus:outline-none focus:border-primary/50 transition-colors duration-200"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-white/50 font-barlow text-xs tracking-wider uppercase" for="mensaje">
              Tu proyecto
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              placeholder="Contanos qué tenés en mente..."
              class="bg-[#0D0D0D] border border-white/10 rounded-lg px-4 py-3 text-white font-barlow text-sm
                     placeholder-white/20 focus:outline-none focus:border-primary/50 transition-colors duration-200 resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="btn-primary bg-primary text-white font-barlow font-600 tracking-wider uppercase text-sm px-6 py-3 rounded-xl hover:bg-primary-light transition-colors duration-300 mt-1"
          >
            Enviar consulta
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contacto-bg {
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(200, 131, 26, 0.05) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(200, 131, 26, 0.03) 0%, transparent 50%);
  }
</style>
